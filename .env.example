# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# Type: Backend Secret (Sensitive)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Type: Public Frontend/Backend Configuration
APP_URL="MY_APP_URL"

# ==========================================
# STREAMDDB HARDENING - ENVIRONMENT VARIABLES
# ==========================================

# IPTV Source Playlist URL (M3U format)
# If provided, this URL will be used to synchronize the global IPTV channels catalog.
# Type: Backend Seeding Configuration (Public/Safe)
IPTV_SOURCE_URL="https://raw.githubusercontent.com/abusaeeidx/Mrgify-BDIX-IPTV/main/playlist.m3u"

# --- Firebase Public Client Credentials ---
# These are used by the React frontend to connect to the Firebase project.
# They are safe to expose in client-side HTML/JS but should be managed via environment variables for portability.
# Type: Public Frontend Configuration

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

# --- Optional Relational & JWT Configuration (If used in advanced setups) ---
# Type: Backend Secret (Sensitive)
JWT_SECRET=""
DATABASE_URL=""
